# === Produção: copie para .env na VPS e preencha ===

# Gere uma nova chave: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

DJANGO_SETTINGS_MODULE=config.settings.production

# Hosts permitidos, separados por vírgula (sem espaços): api.cajuina.com.br,cajuina.com.br
ALLOWED_HOSTS=

# Origens confiáveis (com esquema): https://cajuina.com.br
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=https://cajuina.com.br

# Porta exposta no host (127.0.0.1:API_PORT). Default 8000; mude se já estiver em uso.
API_PORT=8000

# Banco de dados
POSTGRES_DB=cajuina_db
POSTGRES_USER=cajuina
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432
